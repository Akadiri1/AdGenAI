{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "npx prisma generate && next build",
  "regions": ["iad1"],
  "functions": {
    "src/app/api/generate/magic/route.ts": { "maxDuration": 60 },
    "src/app/api/generate/advanced/route.ts": { "maxDuration": 60 },
    "src/app/api/generate/avatar/route.ts": { "maxDuration": 60 },
    "src/app/api/generate/storyboard/route.ts": { "maxDuration": 60 },
    "src/app/api/generate/variants/route.ts": { "maxDuration": 60 },
    "src/app/api/ads/[id]/video/route.ts": { "maxDuration": 60 },
    "src/app/api/ai/rephrase/route.ts": { "maxDuration": 30 },
    "src/app/api/ai/ugc-script/route.ts": { "maxDuration": 30 },
    "src/app/api/tools/hook-generator/route.ts": { "maxDuration": 30 },
    "src/app/api/billing/webhook/route.ts": { "maxDuration": 60 },
    "src/app/api/billing/paystack/webhook/route.ts": { "maxDuration": 60 }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(self), geolocation=()" }
      ]
    }
  ]
}
